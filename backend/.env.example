PORT=8080
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# Either set DATABASE_URL or the discrete DB_* variables.
DATABASE_URL=mysql://leads_user:leads_pass@127.0.0.1:3306/LeadsDB

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=leads_user
DB_PASSWORD=leads_pass
DB_NAME=LeadsDB

ALL_EXCEL_PATH=/Users/apple/Documents/LeadAnalysis.xlsx
CONV_EXCEL_PATH=/Users/apple/Documents/LeadConverted.xlsx

# Aggregated ML scoring params
ML_ALPHA=1
ML_BETA=1
ML_LEAD_STATUS_FLOOR=0.001
# ML_MODEL_VERSION=agg_20260407_120000

# --- Bedrock email generation (Node reads plain strings only; no Python expressions) ---
# Required for invoke: region + model id + credentials (or default AWS credential chain).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Preferred: set the Bedrock model or inference profile id (one line, no spaces around =).
# Example: meta.llama3-70b-instruct-v1:0
BEDROCK_MODEL_ID=

# Optional fallback: strict JSON map display name -> model id (single line).
# Example: {"Llama370B":"meta.llama3-70b-instruct-v1:0"}
AVAILABLE_MODELS=

# Optional inference profile (if set, takes precedence over BEDROCK_MODEL_ID per resolve order in code)
# BEDROCK_INFERENCE_PROFILE_ARN=
# BEDROCK_INFERENCE_PROFILE_ID=

BEDROCK_TEMPERATURE=0.3
# Must be below model max (e.g. Llama 3 70B on Bedrock: use 2000 or less; code caps at 2047 unless BEDROCK_MAX_TOKENS_CAP is set)
BEDROCK_MAX_TOKENS=2000
# Optional: raise ceiling for models with higher output limits (default cap 2047)
# BEDROCK_MAX_TOKENS_CAP=8192
LEAD_MAIL_SCHEDULE_MINUTES=60

# Diagnostics: GET http://localhost:8080/api/ml/bedrock-email-env (no Bedrock invoke; checks env + SDK load)
